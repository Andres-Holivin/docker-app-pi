# Copy this file to .env.custom when you need host-specific overrides.
# The upstream .env file stays pinned in git; .env.custom is ignored.

# Public bind port already defaults to 9001 in .env for this repo.
# Override it here only if you need a different host port.
# SENTRY_BIND=9001

# Generate and persist your own Sentry system secret if you do not want
# install.sh to manage it interactively.
# SENTRY_SYSTEM_SECRET_KEY=

# Leave mail disabled until you are ready to wire a real relay/provider.
# SENTRY_MAIL_HOST=
# SES_USER=
# SES_PASSWORD=
# SES_REGION=

# Reduce feature surface if this host cannot handle the full stack.
# COMPOSE_PROFILES=errors-only

# Optional: shorten retention to save disk.
# SENTRY_EVENT_RETENTION_DAYS=30

# Optional: disable telemetry prompts during install.
# REPORT_SELF_HOSTED_ISSUES=0